    <script>
        // ฟังก์ชันอัปเดตเวลาเรียลไทม์
        function updateClock() {
            const now = new Date();
            const timeString = now.toTimeString().split(' ')[0];
            document.getElementById('live-clock').innerText = timeString;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // ระบบจำลองการแสกนนิ้วเมื่อกดปุ่ม
        const fingerprintBtn = document.getElementById('fingerprint-btn');
        const authStatus = document.getElementById('auth-status');
        const integrityPercent = document.getElementById('integrity-percent');

        fingerprintBtn.addEventListener('click', () => {
            authStatus.innerText = "กำลังสแกนและตรวจสอบสิทธิ์...";
            authStatus.classList.remove('text-purple-300', 'text-green-400', 'text-red-400');
            authStatus.classList.add('text-yellow-400');
            
            // จำลองการประมวลผลดีเลย์ 1.3 วินาที
            setTimeout(() => {
                authStatus.innerText = "ยินดีต้อนรับ! peeyoulike909@gmail.com ยืนยันตัวตนสำเร็จ";
                authStatus.classList.remove('text-yellow-400');
                authStatus.classList.add('text-green-400');
                integrityPercent.innerText = "100% SECURE";
                integrityPercent.classList.add('text-green-400');
            }, 1500);
        });
